# ============================================================
# Gold Sentinel — 环境变量配置模板
# 复制本文件为 .env 并填写真实值
# ============================================================

# ── 应用配置 ────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
LOG_LEVEL=info

# ── 数据库 ──────────────────────────────────────────────────
SQLITE_DB_PATH=./data/db/gold-sentinel.db

# ── 价格 API Keys ────────────────────────────────────────────
# ★ MetalpriceAPI — 免费100次/月，无需信用卡
#   注册: https://metalpriceapi.com/register
METALPRICE_API_KEY=

# ★ GoldAPI.io — 免费，Google账号30秒登录，实时XAU/XAG
#   注册: https://www.goldapi.io/  (点击 "Get Free API Key")
GOLDAPI_KEY=

# Metals-API — 免费层仅1次/天刷新，作三级备用
#   注册: https://metals-api.com/register
METALS_API_KEY=

# ── 宏观数据 API Keys ────────────────────────────────────────
# ★ FRED API — 完全免费无限制，只需邮箱注册，强烈推荐必填
#   注册: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# NewsAPI — 免费500次/天（开发环境），仅限非商业用途
#   注册: https://newsapi.org/register
NEWS_API_KEY=

# Truth Social — 可选 Bearer Token（不填也能读取公开帖子，填写后更稳定）
# 获取方式：登录 Truth Social → 开发者工具 → Network → 找任意请求的 Authorization 头
# 格式: Bearer xxxxxxxxxxxxxxxx
TRUTH_SOCIAL_BEARER_TOKEN=

# ── 汇率 API ─────────────────────────────────────────────────
# ★ ExchangeRate-API — 免费1500次/月，无需信用卡，邮箱确认即用
#   注册: https://app.exchangerate-api.com/sign-up
#   (也可用无Key的开放接口: https://www.exchangerate-api.com/docs/free)
EXCHANGE_RATE_API_KEY=your_exchangerate_api_key_here

# ── AI 分析 ──────────────────────────────────────────────────
# 方案A: Anthropic Claude API (官方)
# https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# 模型选择: claude-opus-4-6 / claude-sonnet-4-6 / claude-haiku-4-5-20251001
AI_MODEL=claude-haiku-4-5-20251001

# 方案B: 自定义模型端点（优先级高于方案A，兼容 OpenAI Chat Completions 格式）
# 适用于: Ollama / LM Studio / vLLM / 本地部署 / 第三方代理
# 示例: http://192.168.1.100:11434/v1  (Ollama)
#        http://localhost:1234/v1       (LM Studio)
#        https://your-proxy.com/v1     (第三方代理)
AI_CUSTOM_BASE_URL=
# 自定义端点的 API Key（Ollama 可填任意字符串，LM Studio 填 lm-studio）
AI_CUSTOM_API_KEY=
# 自定义模型名称（如 qwen2.5:14b / llama3.1:8b / deepseek-r1:7b）
AI_CUSTOM_MODEL=

# ── 推送渠道 ─────────────────────────────────────────────────
# 钉钉群机器人 Webhook
DINGTALK_WEBHOOK=https://oapi.dingtalk.com/robot/send?access_token=xxx
DINGTALK_SECRET=your_dingtalk_secret_here

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# 邮件推送 (SMTP)
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your_email@qq.com
SMTP_PASS=your_smtp_password_here
EMAIL_TO=recipient@example.com

# ── 告警阈值 ─────────────────────────────────────────────────
# 价格波动告警: 1分钟内波动超过此百分比触发 (default: 0.5%)
PRICE_ALERT_THRESHOLD=0.5

# COMEX 库存告警: 单日变化超过 N 标准差触发 (default: 2)
INVENTORY_ALERT_SIGMA=2

# GLD ETF 持仓告警: 单日变化超过 N 吨触发 (default: 5)
ETF_ALERT_TONNES=5

# ── 数据保留策略 ─────────────────────────────────────────────
# 分钟级价格数据保留天数 (default: 90)
MINUTE_DATA_RETENTION_DAYS=90
